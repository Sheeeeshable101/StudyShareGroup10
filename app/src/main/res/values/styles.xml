<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.StudyShare.FeatureRow" parent="@android:style/Widget.TextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:background">@drawable/bg_feature_row</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:paddingVertical">14dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.BodyLarge</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="ShapeAppearance.StudyShare.ProfileImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
